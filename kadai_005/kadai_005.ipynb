      "source": [
        "# 上辺:10cm\n",
        "# 下辺:20cm\n",
        "# 高さ:5cm\n",
        "# 公式:台形の面積＝(上辺＋下辺)×高さ÷2\n",
        "# 出力結果は「〇〇cm2」となるように単位をつける。\n",
        "\n",
        "top_side=10\n",
        "bottom_side=20\n",
        "height=5\n",
        "area=(top_side+bottom_side)*height/2\n",
        "\n",
        "print(f\"面積は{area}cm2です\")"
      ]
    },
